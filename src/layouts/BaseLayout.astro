---
// Root layout: HTML shell, theme variables, fonts, SEO/OG meta tags,
// header, footer, and global behavior scripts.
import siteConfig from '../../site.config.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
  articleSlug?: string;
  prevUrl?: string;
  nextUrl?: string;
  noindex?: boolean;
  jsonLd?: object;
}

const {
  title,
  description = siteConfig.site.description,
  image,
  imageWidth,
  imageHeight,
  type = 'website',
  articleSlug,
  prevUrl,
  nextUrl,
  noindex = false,
  jsonLd,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const pageTitle = title === siteConfig.site.name ? title : `${title} - ${siteConfig.site.name}`;

const siteOrigin = import.meta.env.SITE_URL || siteConfig.site.url;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);

// OG image: use article image if provided, otherwise fall back to the
// default PNG (not SVG — Twitter/Facebook/WeChat don't support SVG previews).
const ogImage = image
  ? image
  : new URL(`${base}og-default.png`, siteOrigin).toString();
const ogImgWidth  = image ? (imageWidth  ?? 1200) : 1200;
const ogImgHeight = image ? (imageHeight ?? 630)  : 630;

// Font URL: only 2 weights per family (400+700) to minimise download size.
// 900 was only used for card titles which render fine at 700 on most screens.
const fontsUrl = 'https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&family=Noto+Serif+SC:wght@700;900&display=swap';
---

<!DOCTYPE html>
<html lang={siteConfig.site.lang} style={`
  --color-bg: ${siteConfig.theme.backgroundColor};
  --color-surface: ${siteConfig.theme.surfaceColor};
  --color-border: ${siteConfig.theme.borderColor};
  --color-text: ${siteConfig.theme.textPrimary};
  --color-text-secondary: ${siteConfig.theme.textSecondary};
  --color-primary: ${siteConfig.theme.primaryColor};
  --color-primary-dark: ${siteConfig.theme.primaryColorDark};
  --color-accent: ${siteConfig.theme.accentColor};
  --color-link-visited: ${siteConfig.theme.linkVisitedColor};
  --font-heading: ${siteConfig.fonts.headingFont};
  --font-body: ${siteConfig.fonts.bodyFont};
`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href={`${base}${siteConfig.branding.favicon.replace(/^\//, '')}`} type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.site.name} />

    <!-- Open Graph — og:type must be 'article' on article pages for
         social platforms to generate proper news preview cards. -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImgWidth)} />
    <meta property="og:image:height" content={String(ogImgHeight)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={siteConfig.site.locale} />
    <meta property="og:site_name" content={siteConfig.site.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.site.name}
      href={new URL('rss.xml', siteOrigin).toString()}
    />

    <!-- Fonts: async load to avoid render-blocking.
         onload trick swaps rel from preload to stylesheet after download.
         noscript fallback ensures fonts load without JS. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href={fontsUrl}
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href={fontsUrl} />
    </noscript>

    <!-- Google AdSense -->
    {siteConfig.ads.adsenseClientId && siteConfig.ads.adsenseClientId !== 'ca-pub-0000000000000000' && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.ads.adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="shell main-content">
      <slot />
    </main>
    <Footer />

    <script define:vars={{ articleSlug }}>
      // Mark articles as read using localStorage
      const READ_KEY = 'cn-news-hub:read';

      function getReadSet() {
        try {
          const raw = localStorage.getItem(READ_KEY);
          return new Set(raw ? JSON.parse(raw) : []);
        } catch {
          return new Set();
        }
      }

      function saveReadSet(set) {
        try {
          localStorage.setItem(READ_KEY, JSON.stringify(Array.from(set)));
        } catch {}
      }

      if (articleSlug) {
        const readSet = getReadSet();
        readSet.add(articleSlug);
        saveReadSet(readSet);
      }

      const readSet = getReadSet();
      document.querySelectorAll('[data-slug]').forEach((card) => {
        const slug = card.getAttribute('data-slug');
        if (slug && readSet.has(slug)) card.classList.add('is-read');
      });
    </script>
  </body>
</html>
