---
// Root layout: HTML shell, theme variables, fonts, SEO/OG meta tags,
// header, footer, and global behavior scripts.
import siteConfig from '../../site.config.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  articleSlug?: string;
  // Pagination SEO: pass these on list pages to emit <link rel="prev/next">
  prevUrl?: string;
  nextUrl?: string;
  // Pass true on pages that should not be indexed (e.g. /admin/)
  noindex?: boolean;
  // JSON-LD structured data blob (serialised by caller)
  jsonLd?: object;
}

const {
  title,
  description = siteConfig.site.description,
  image,
  type = 'website',
  articleSlug,
  prevUrl,
  nextUrl,
  noindex = false,
  jsonLd,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const pageTitle = title === siteConfig.site.name ? title : `${title} - ${siteConfig.site.name}`;

// Derive the canonical site origin from the SITE_URL env var injected at
// build time by the GitHub Actions workflow (read from public/CNAME).
// Falls back to site.config.json only for local builds without SITE_URL.
const siteOrigin = import.meta.env.SITE_URL || siteConfig.site.url;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);

const ogImage = image
  ? image
  : new URL(`${base}${siteConfig.branding.ogDefaultImage.replace(/^\//, '')}`, siteOrigin).toString();
const ogImageIsDefault = !image;
---

<!DOCTYPE html>
<html lang={siteConfig.site.lang} style={`
  --color-bg: ${siteConfig.theme.backgroundColor};
  --color-surface: ${siteConfig.theme.surfaceColor};
  --color-border: ${siteConfig.theme.borderColor};
  --color-text: ${siteConfig.theme.textPrimary};
  --color-text-secondary: ${siteConfig.theme.textSecondary};
  --color-primary: ${siteConfig.theme.primaryColor};
  --color-primary-dark: ${siteConfig.theme.primaryColorDark};
  --color-accent: ${siteConfig.theme.accentColor};
  --color-link-visited: ${siteConfig.theme.linkVisitedColor};
  --font-heading: ${siteConfig.fonts.headingFont};
  --font-body: ${siteConfig.fonts.bodyFont};
`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href={`${base}${siteConfig.branding.favicon.replace(/^\//, '')}`} type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Indexing control -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Pagination discovery for search engines -->
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {ogImageIsDefault && <meta property="og:image:type" content="image/svg+xml" />}
    {ogImageIsDefault && <meta property="og:image:width" content="1200" />}
    {ogImageIsDefault && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content={siteConfig.site.locale} />
    <meta property="og:site_name" content={siteConfig.site.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data (NewsArticle, WebSite, etc.) -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- RSS feed autodiscovery: allows browsers, RSS readers, and AI
         crawlers to find the feed without explicit navigation. -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.site.name}
      href={new URL('rss.xml', siteOrigin).toString()}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={siteConfig.fonts.googleFontsUrl} as="style" />
    <link rel="stylesheet" href={siteConfig.fonts.googleFontsUrl} />

    <!-- Google AdSense: always present for ownership verification.
         Actual ad slots are gated by ads.enabled in site.config.json. -->
    {siteConfig.ads.adsenseClientId && siteConfig.ads.adsenseClientId !== 'ca-pub-0000000000000000' && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.ads.adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="shell main-content">
      <slot />
    </main>
    <Footer />

    <script define:vars={{ articleSlug }}>
      document.addEventListener('contextmenu', (e) => e.preventDefault());

      const READ_KEY = 'cn-news-hub:read';

      function getReadSet() {
        try {
          const raw = localStorage.getItem(READ_KEY);
          return new Set(raw ? JSON.parse(raw) : []);
        } catch {
          return new Set();
        }
      }

      function saveReadSet(set) {
        try {
          localStorage.setItem(READ_KEY, JSON.stringify(Array.from(set)));
        } catch { /* localStorage unavailable - degrade silently */ }
      }

      if (articleSlug) {
        const readSet = getReadSet();
        readSet.add(articleSlug);
        saveReadSet(readSet);
      }

      const readSet = getReadSet();
      document.querySelectorAll('[data-slug]').forEach((card) => {
        const slug = card.getAttribute('data-slug');
        if (slug && readSet.has(slug)) card.classList.add('is-read');
      });
    </script>
  </body>
</html>
