---
// A single news item rendered as a list row: small thumbnail on the left,
// category/date/title/excerpt/source on the right. Designed for dense
// scanning of 20-30 items per page. The full-size image is shown on the
// article detail page (see article__hero), not here.
import type { CollectionEntry } from 'astro:content';
import siteConfig from '../../site.config.json';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
const { title, pubDate, sourceName, category, image, description } = entry.data;

const categoryLabel =
  siteConfig.categories.find((c) => c.id === category)?.label ?? category;

function formatDate(date: Date): string {
  return `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
}
---

<article class="card" data-slug={entry.slug}>
  {image ? (
    <a href={`${base}article/${entry.slug}/`} class="card__media" aria-hidden="true" tabindex="-1">
      <img
        src={image}
        alt=""
        loading="lazy"
        width="240"
        height="180"
        onerror="this.closest('.card__media').remove()"
      />
    </a>
  ) : null}
  <div class="card__body">
    <div class="card__top">
      <span class="card__category">{categoryLabel}</span>
      <span class="card__date">{formatDate(pubDate)}</span>
    </div>
    <h3 class="card__title">
      <a href={`${base}article/${entry.slug}/`}>{title}</a>
    </h3>
    <p class="card__excerpt">{description}</p>
    <div class="card__meta">
      <span>{sourceName}</span>
    </div>
  </div>
</article>
