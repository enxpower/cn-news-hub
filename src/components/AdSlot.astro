---
// Google AdSense native/in-feed ad slot.
// Styled identically to surrounding cards/content so ads never feel
// jarring. Controlled entirely by site.config.json - if the master switch
// or this position's switch is off, nothing renders at all.
import siteConfig from '../../site.config.json';

interface Props {
  // Key into site.config.json -> ads.positions
  position: 'listInFeed' | 'articleBottom';
  // When true, render as a grid item (same shape as a card)
  asCard?: boolean;
}

const { position, asCard = false } = Astro.props;
const adsConfig = siteConfig.ads;
const posConfig = adsConfig.positions[position];
const enabled = adsConfig.enabled && posConfig?.enabled;
---

{enabled && (
  <div class:list={["ad-slot", { "card": asCard, "ad-slot--article": position === "articleBottom" }]}>
    <span class="ad-slot__label">广告</span>
    <ins
      class="adsbygoogle"
      style="display:block; width:100%; height:100%;"
      data-ad-client={adsConfig.adsenseClientId}
      data-ad-slot={posConfig.slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsConfig.adsenseClientId}`} crossorigin="anonymous"></script>
    <script>
      try {
        // @ts-ignore - global provided by AdSense script
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (e) {
        /* AdSense not yet loaded or blocked - fail silently, slot stays empty */
      }
    </script>
  </div>
)}
