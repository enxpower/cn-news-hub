---
import siteConfig from '../../site.config.json';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

function isActive(href: string): boolean {
  const normalized = (base + href).replace(/\/+/g, '/');
  return currentPath === normalized || currentPath === normalized + '/'
    || (href === '' && (currentPath === base || currentPath === base + '/'));
}
---

<header class="site-header">
  <div class="shell site-header__bar">
    <a href={base} class="site-header__brand" aria-label={siteConfig.site.name}>
      <img src={`${base}${siteConfig.branding.logoImage.replace(/^\//, '')}`} alt="" width="32" height="32" />
      <span>{siteConfig.branding.logoText}</span>
    </a>
    <span class="site-header__tagline">{siteConfig.site.tagline}</span>
    <div class="font-size-control" role="group" aria-label="字号调节">
      <button type="button" data-font-size="sm" aria-label="缩小字号">A-</button>
      <button type="button" data-font-size="md" aria-label="标准字号">A</button>
      <button type="button" data-font-size="lg" aria-label="放大字号">A+</button>
    </div>
  </div>
  <nav class="site-nav" aria-label="新闻分类">
    <div class="shell">
      <ul class="site-nav__list">
        <li>
          <a class:list={["site-nav__link", { "is-active": isActive('') }]} href={base}>滚动</a>
        </li>
        {siteConfig.categories.map((cat) => (
          <li>
            <a
              class:list={["site-nav__link", { "is-active": isActive(`category/${cat.id}/`) }]}
              href={`${base}category/${cat.id}/`}
            >
              {cat.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const SIZES: Record<string, string> = { sm: '15px', md: '16px', lg: '19px' };
  const STORAGE_KEY = 'cn-news-hub:font-size';

  function applySize(size: string) {
    const px = SIZES[size] ?? SIZES.md;
    document.documentElement.style.setProperty('--user-font-size', px);
  }

  const saved = localStorage.getItem(STORAGE_KEY) ?? 'md';
  applySize(saved);

  document.querySelectorAll<HTMLButtonElement>('.font-size-control button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const size = btn.dataset.fontSize ?? 'md';
      localStorage.setItem(STORAGE_KEY, size);
      applySize(size);
    });
  });
</script>
