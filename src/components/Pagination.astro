---
// Prev/next + numbered pagination. basePath should be the section root
// (e.g. "/" or "/category/finance/") without a trailing page number.
// Page 1 lives at basePath itself; page N>1 lives at `${basePath}page/${N}/`.
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const base = import.meta.env.BASE_URL;

function pageHref(page: number): string {
  const root = `${base}${basePath}`.replace(/\/+/g, '/');
  if (page <= 1) return root;
  return `${root}page/${page}/`.replace(/\/+/g, '/');
}

const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;

// Always show a fixed-width window of WINDOW_SIZE numbered buttons (clamped
// to totalPages) so the control bar has the same number of elements on
// every page - e.g. page 1 of a 10-page section shows "1 2 3 … 下一页"
// (3 numbers), not just "1 2 …", matching page 2's "1 2 3 … 下一页". This
// keeps the total button count (and therefore the row width) consistent
// across pages instead of growing by one near the edges.
const WINDOW_SIZE = 3;
let start = currentPage - 1;
let end = currentPage + 1;
if (start < 1) {
  end += 1 - start;
  start = 1;
}
if (end > totalPages) {
  start -= end - totalPages;
  end = totalPages;
}
start = Math.max(1, start);

const pages: number[] = [];
for (let p = start; p <= end; p++) {
  pages.push(p);
}

// The "…" ellipsis is purely decorative (indicates skipped page numbers) and
// is not a control - it has no destination. Rendering it with the same
// bordered/min-width button styling as the real controls makes it look
// clickable, which is confusing on both desktop and mobile/tablet. Style it
// inline as plain, non-interactive text instead.
const ellipsisStyle =
  'border:none;background:transparent;min-width:auto;height:auto;padding:0 2px;cursor:default;';
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="分页导航">
    {hasPrev ? (
      <a href={pageHref(currentPage - 1)} rel="prev">上一页</a>
    ) : (
      <span class="is-disabled">上一页</span>
    )}

    {pages[0] > 1 && <span class="is-disabled" aria-hidden="true" style={ellipsisStyle}>…</span>}

    {pages.map((p) =>
      p === currentPage ? (
        <span class="is-current" aria-current="page">{p}</span>
      ) : (
        <a href={pageHref(p)}>{p}</a>
      )
    )}

    {pages[pages.length - 1] < totalPages && <span class="is-disabled" aria-hidden="true" style={ellipsisStyle}>…</span>}

    {hasNext ? (
      <a href={pageHref(currentPage + 1)} rel="next">下一页</a>
    ) : (
      <span class="is-disabled">下一页</span>
    )}
  </nav>
)}
