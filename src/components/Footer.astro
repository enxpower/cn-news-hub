---
// Site footer: links and the RSS-aggregation disclaimer (legal attribution).
import siteConfig from '../../site.config.json';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell">
    <div class="site-footer__links">
      {siteConfig.footer.links.map((link) => (
        <a href={`${base}${link.href.replace(/^\//, '')}`}>{link.label}</a>
      ))}
    </div>
    <p class="site-footer__disclaimer">{siteConfig.footer.disclaimer}</p>
    <p>&copy; {year} {siteConfig.footer.copyrightName}</p>
  </div>
</footer>
