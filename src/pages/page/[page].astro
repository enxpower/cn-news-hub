---
// Pages 2..N of the rolling "涩动新闻" feed. Page 1 lives at "/".
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsList from '../../components/NewsList.astro';
import siteConfig from '../../../site.config.json';
import { getAllArticlesSorted, paginate, totalPagesFor } from '../../lib/articles';

export async function getStaticPaths() {
  const all = await getAllArticlesSorted();
  const totalPages = totalPagesFor(all.length);
  const paths = [];
  for (let p = 2; p <= totalPages; p++) {
    paths.push({ params: { page: String(p) } });
  }
  return paths;
}

const { page } = Astro.params;
const currentPage = Number(page);
const all = await getAllArticlesSorted();
const entries = paginate(all, currentPage);
const totalPages = totalPagesFor(all.length);
---

<BaseLayout title={`涩动新闻 - 第 ${currentPage} 页`} description={siteConfig.site.description}>
  <NewsList
    heading="涩动新闻"
    headingMeta={`第 ${currentPage} / ${totalPages} 页`}
    entries={entries}
    currentPage={currentPage}
    totalPages={totalPages}
    basePath=""
  />
</BaseLayout>
