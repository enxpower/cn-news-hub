---
// Article detail page. Large hero image, clear source attribution
// (required for RSS reproduction), and full body content.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import siteConfig from '../../../site.config.json';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, pubDate, sourceName, sourceUrl, category, image, description } = entry.data;
const { Content } = await render(entry);

const base = import.meta.env.BASE_URL;
const categoryLabel = siteConfig.categories.find((c) => c.id === category)?.label ?? category;

function formatDate(date: Date): string {
  return `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
}
---

<BaseLayout title={title} description={description} image={image} type="article" articleSlug={entry.slug}>
  <p class="article__breadcrumb">
    <a href={base}>{siteConfig.site.shortName}</a> &gt;
    <a href={`${base}category/${category}/`}>{categoryLabel}</a>
  </p>

  <article class="article">
    <h1 class="article__title">{title}</h1>
    <div class="article__meta">
      <span class="article__category-badge">{categoryLabel}</span>
      <span>{formatDate(pubDate)}</span>
    </div>

    {image && (
      <div class="article__hero">
        <img src={image} alt="" width="1200" height="675" />
      </div>
    )}

    <div class="source-box">
      <span>来源：{sourceName}</span>
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer nofollow" class="source-box__link">查看原文</a>
    </div>

    <div class="article__body">
      <Content />
    </div>

    <div class="article__footer">
      <AdSlot position="articleBottom" />
      <a class="back-link" href={`${base}category/${category}/`}>&larr; 返回{categoryLabel}列表</a>
    </div>
  </article>
</BaseLayout>
