---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import siteConfig from '../../../site.config.json';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, pubDate, sourceName, sourceUrl, category, image, description } = entry.data;
const { Content } = await render(entry);

const base = import.meta.env.BASE_URL;
const siteOrigin = import.meta.env.SITE_URL || siteConfig.site.url;
const categoryLabel = siteConfig.categories.find((c) => c.id === category)?.label ?? category;

function formatDate(date: Date): string {
  return `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
}

// Validate sourceUrl protocol - block javascript: XSS from untrusted feeds
function safeSourceUrl(url: string): string {
  try {
    const parsed = new URL(url);
    return parsed.protocol === 'https:' || parsed.protocol === 'http:' ? url : '#';
  } catch {
    return '#';
  }
}
const safeUrl = safeSourceUrl(sourceUrl);
const canonicalUrl = new URL(`${base}article/${entry.slug}/`, siteOrigin).toString();

// JSON-LD: NewsArticle schema
// Helps Google News, AI search engines (Perplexity, ChatGPT browsing, etc.)
// understand article metadata and increases eligibility for rich results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description,
  url: canonicalUrl,
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  image: image ? [image] : undefined,
  author: {
    '@type': 'Organization',
    name: sourceName,
    url: safeUrl !== '#' ? safeUrl : undefined,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.site.name,
    url: siteOrigin,
    logo: {
      '@type': 'ImageObject',
      url: new URL('logo.svg', siteOrigin).toString(),
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  inLanguage: siteConfig.site.lang,
  articleSection: categoryLabel,
  isAccessibleForFree: true,
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  articleSlug={entry.slug}
  jsonLd={jsonLd}
>
  <p class="article__breadcrumb">
    <a href={base}>{siteConfig.site.shortName}</a> &gt;
    <a href={`${base}category/${category}/`}>{categoryLabel}</a>
  </p>

  <article class="article">
    <h1 class="article__title">{title}</h1>
    <div class="article__meta">
      <span class="article__category-badge">{categoryLabel}</span>
      <span>{formatDate(pubDate)}</span>
    </div>

    {image && (
      <div class="article__hero">
        <img src={image} alt={title} width="1200" height="675" onerror="this.closest('.article__hero').remove()" />
      </div>
    )}

    <div class="source-box">
      <span>来源：{sourceName}</span>
      {safeUrl !== '#' && (
        <a href={safeUrl} target="_blank" rel="noopener noreferrer nofollow" class="source-box__link">查看原文</a>
      )}
    </div>

    <div class="article__body">
      <Content />
    </div>

    <div class="article__footer">
      <AdSlot position="articleBottom" />
      <a
        class="back-link"
        href={`${base}category/${category}/`}
        onclick="window.history.back(); return false;"
      >&larr; 返回上一页</a>
    </div>
  </article>

  {image && (
    <script define:vars={{ heroImage: image }}>
      function imgPathKey(url) {
        try {
          const u = new URL(url, location.href);
          return u.pathname.replace(/[_-]\d{2,4}[x_]\d{2,4}/gi, '').toLowerCase();
        } catch {
          return url.toLowerCase();
        }
      }

      function isIconImage(img) {
        const src = img.src || '';
        if (/icon|logo|tag|avatar|sprite|badge/i.test(src)) return true;
        if (img.complete && img.naturalWidth > 0 && img.naturalWidth < 60) return true;
        return false;
      }

      const body = document.querySelector('.article__body');
      if (body) {
        const heroKey = imgPathKey(heroImage);
        body.querySelectorAll('img').forEach((img) => {
          if (isIconImage(img)) { (img.closest('figure') || img).remove(); return; }
          if (imgPathKey(img.src) === heroKey) (img.closest('figure') || img).remove();
        });
      }
    </script>
  )}
</BaseLayout>
